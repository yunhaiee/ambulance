# Gemini API (또는 GOOGLE_GENAI_USE_VERTEXAI=TRUE 로 Vertex AI 사용)
GOOGLE_API_KEY=your-google-api-key

# 모든 에이전트가 사용하는 모델 (기본값: gemini-2.5-flash-lite)
AGENT_MODEL=gemini-2.5-flash-lite

# A2A 상호 인증용 공유 토큰 - 5개 에이전트 모두 동일한 값으로 설정할 것.
A2A_AUTH_TOKEN=

# Kakao Mobility / Local REST API
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Slack (교통사고 보고용, chat:write 스코프 필요)
# SLACK_TEAM_ID는 더 이상 필요 없음 (직접 API 호출로 전환)
SLACK_BOT_TOKEN=xoxb-...
# 한국교통안전공단 보고 채널
TRAFFIC_SAFETY_SLACK_CHANNEL_ID=C0968E2P03Z

# 세션/태스크 DB 저장 위치 (기본 ~/.ambulance)
# AMBULANCE_DATA_DIR=~/.ambulance
