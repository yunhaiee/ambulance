# 공유 비밀키 (.env) - 병원 정체성은 configs/<병원>.env 프로필에 있음
# 실행: HOSPITAL_PROFILE=configs/대전선병원.env uv run .

# Gemini API (또는 GOOGLE_GENAI_USE_VERTEXAI=TRUE 로 Vertex AI 사용)
GOOGLE_API_KEY=your-google-api-key

# 모든 에이전트가 사용하는 모델 (기본값: gemini-2.5-flash-lite)
AGENT_MODEL=gemini-2.5-flash-lite

# A2A 상호 인증용 공유 토큰 - 5개 에이전트 모두 동일한 값으로 설정할 것.
A2A_AUTH_TOKEN=

# Notion (병원 의료진/공간 현황 DB)
NOTION_API_KEY=ntn_...

# Slack (병원 내부 보고용, chat:write 스코프 필요)
SLACK_BOT_TOKEN=xoxb-...

# 세션/태스크 DB 저장 위치 (기본 ~/.ambulance - iCloud 동기화 폴더 밖이어야 함)
# AMBULANCE_DATA_DIR=~/.ambulance
