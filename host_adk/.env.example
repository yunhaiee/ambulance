# Gemini API (또는 GOOGLE_GENAI_USE_VERTEXAI=TRUE 로 Vertex AI 사용)
GOOGLE_API_KEY=your-google-api-key

# 호스트(구급) 에이전트 모델 - KTAS 의료 판단 노드라 상위 모델 사용.
# 속도 우선이면 gemini-2.5-flash 로 변경 가능.
AGENT_MODEL=gemini-2.5-pro

# A2A 상호 인증용 공유 토큰 - 5개 에이전트 모두 동일한 값으로 설정할 것.
# 생성 예: openssl rand -hex 32
A2A_AUTH_TOKEN=

# 원격 에이전트 주소 (기본값: 아래 4개)
# REMOTE_AGENT_URLS=http://localhost:10002,http://localhost:10003,http://localhost:10004,http://localhost:10005

# A2A 호출 타임아웃(초) / 병원 병렬 문의 병원당 타임아웃(초)
# A2A_CALL_TIMEOUT_S=45
# HOSPITAL_DISPATCH_TIMEOUT_S=45

# 감사로그(dispatch_audit.jsonl) 저장 위치 (기본 ~/.ambulance - iCloud 동기화 폴더 밖!)
# AMBULANCE_DATA_DIR=~/.ambulance
